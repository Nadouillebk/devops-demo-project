pipeline {
    agent any

    tools {
        maven 'Maven 3.9.9'
    }

    environment {
        SONAR_TOKEN = credentials('sonarqube')
    }

    stages {
        stage('Build') {
            steps {
                echo 'Compilation avec Maven...'
                // Exécuter Maven depuis la racine du repo (remonter d'un dossier)
                dir('../../') {
                    sh 'mvn clean install'
                }
            }
        }

        stage('Analyse SonarQube') {
            steps {
                echo 'Analyse SonarQube...'
                dir('../../') {
                    sh '''
                        mvn sonar:sonar \
                          -Dsonar.projectKey=demo-java-app \
                          -Dsonar.host.url=http://sonarqube:9000 \
                          -Dsonar.login=$SONAR_TOKEN
                    '''
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo 'Build et push de l\'image Docker...'
                dir('.') { // on est déjà dans ci/jenkins
                    // Construire l'image avec le contexte racine (../..)
                    sh 'docker build -f Dockerfile -t monimage ../../'
                    // Ajouter docker push si besoin
                }
            }
        }
    }
}
