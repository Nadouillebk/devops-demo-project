pipeline {
    agent any

    tools {
        maven 'Maven 3.9.9'
    }

    environment {
        SONAR_TOKEN = credentials('sonarqube')
    }

    stages {
        stage('Build') {
            steps {
                echo 'Compilation avec Maven...'
                dir('ci/Jenkins') {
                    sh 'mvn clean install'
                }
            }
        }

        stage('Analyse SonarQube') {
            steps {
                echo 'Analyse SonarQube...'
                dir('ci/Jenkins') {
                    sh '''
                        mvn sonar:sonar \
                          -Dsonar.projectKey=demo-java-app \
                          -Dsonar.host.url=http://172.16.23.150:9000 \
                          -Dsonar.login=$SONAR_TOKEN
                    '''
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo 'Build et push de l\'image Docker...'
                dir('ci/Jenkins') {
                    sh 'docker build -t monimage .'
                    // Ajoute ici ton docker push si besoin
                }
            }
        }
    }
}
