pipeline {
    agent any

    tools {
        maven 'Maven 3.9.9'
    }

    environment {
        SONAR_TOKEN = credentials('sonarqube')
    }

    parameters {
        string(name: 'TAG', defaultValue: 'v1.0', description: 'Tag de l\'image Docker')
    }

    stages {
        stage('Build') {
            steps {
                echo "Building with tag: ${params.TAG}"
                echo 'Compilation avec Maven...'
                sh 'mvn clean package'
            }
        }

        stage('Analyse SonarQube') {
            steps {
                echo 'Analyse SonarQube...'
                sh '''
                    mvn sonar:sonar \
                      -Dsonar.projectKey=demo-java-app \
                      -Dsonar.host.url=http://sonarqube:9000 \
                      -Dsonar.login=$SONAR_TOKEN
                '''
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo "Build et push de l'image Docker avec tag: ${params.TAG}..."
                sh "docker build -f ci/Jenkins/Dockerfile -t monimage:${params.TAG} ."
                sh "docker push monimage:${params.TAG}"
            }
        }
    }
}
